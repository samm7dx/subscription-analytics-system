# Server
PORT=5000
NODE_ENV=development

# CORS — frontend URL (local + production)
FRONTEND_URL=http://localhost:5173

# MySQL — use DB_* on Render (required names in code)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=subscription_analytics_system

# Aiven / Railway / cloud: set DB_SSL=true
DB_SSL=false

# Optional fallbacks (if your host only provides MYSQL_* from Aiven dashboard):
# MYSQL_HOST=
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# Optional single connection string (overrides DB_* when set):
# DATABASE_URL=mysql://user:password@host:3306/subscription_analytics_system
